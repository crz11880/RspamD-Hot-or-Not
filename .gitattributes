# Auto detect text files and normalize line endings
* text=auto

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown
*.md text eol=lf

# JSON, YAML
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.eml binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
